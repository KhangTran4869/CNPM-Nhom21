# =========================================================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG BACKEND (.env)
# =========================================================================

# 1. Cấu hình Máy chủ Express
PORT=3000

# 2. Cấu hình kết nối Cơ sở dữ liệu (Kết nối tới MySQL Docker hoặc Local)
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASS=123456
DB_NAME=tdk

# 3. Khóa bảo mật mã hóa JWT (JSON Web Token)
JWT_SECRET=super_secret_key_12345